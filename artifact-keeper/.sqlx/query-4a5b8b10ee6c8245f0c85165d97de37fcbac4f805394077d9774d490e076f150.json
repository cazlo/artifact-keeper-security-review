  "query": "\n        SELECT id, path, name, size_bytes, checksum_sha256, content_type, storage_key\n        FROM artifacts\n        WHERE repository_id = $1\n          AND is_deleted = false\n          AND path LIKE '%/' || $2 ESCAPE '\\'\n        LIMIT 1\n        ",
